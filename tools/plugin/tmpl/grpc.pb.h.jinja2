        if (stop_) {
          std::cerr << "Cannot enqueue task on stopped queue" << std::endl;
          return false;
        }
        tasks_.emplace(std::forward<F>(f));
      }
      // Signal one waiting worker thread that a new task is available.
      condition_.Signal();
      return true;
    }

    /**
     * @brief Destructor. Initiates a graceful shutdown of the thread pool.
     * It stops accepting new tasks, waits for all existing tasks to complete,
     * and joins all worker threads.
     */
    ~ThreadPool() {
      {
        absl::MutexLock lock(queue_mutex_);
        stop_ = true;
      }

      condition_.SignalAll();
      for (std::thread& worker : workers_) {
        worker.join();
      }
    }

  private:
    std::vector<std::thread> workers_;
    std::queue<std::function<void()>> tasks_;
    absl::Mutex queue_mutex_;
    absl::CondVar condition_;
    bool stop_ = false;
};
