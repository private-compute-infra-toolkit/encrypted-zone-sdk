oci = use_extension("@rules_oci//oci:extensions.bzl", "oci")
oci.pull(
    name = "isolate_runtime_ubuntu_base",
    # runtime-debian-nondebug-nonroot-amd64, Mar 28, 2025
    digest = "sha256:acf6c2fe4179cd5da18bcf433f0b62467c40f2a42dc821c08cc4ce2f7037813b",
    image = "gcr.io/distroless/cc-debian12",
)
use_repo(oci, "isolate_runtime_ubuntu_base")

# Prevent version skew by matching protoc version to protobuf version, as C++ is the only lang that
# has no cross-version runtime guarantee:
# https://protobuf.dev/support/cross-version-runtime-guarantee/#cpp
protoc = use_extension("@toolchains_protoc//protoc:extensions.bzl", "protoc")
protoc.toolchain(
    google_protobuf = "com_google_protobuf",
    version = "v29.3",
)

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    ignore_root_user_error = True,
    python_version = "3.13",
)
